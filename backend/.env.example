ANTHROPIC_API_KEY=your_anthropic_api_key_here
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# STT: on Render, local faster-whisper is off by default (saves RAM). Use OpenAI Whisper API:
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_TRANSCRIPTION_MODEL=whisper-1

# Force local STT everywhere: USE_LOCAL_WHISPER=true
# Force API STT everywhere: USE_LOCAL_WHISPER=false

# Optional: max PDF upload size (default 10 if unset)
# MAX_PDF_UPLOAD_MB=8
