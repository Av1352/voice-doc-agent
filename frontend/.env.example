# When the UI is on Vercel/Netlify and the API is on Render, set this to your Render service URL (no trailing slash).
VITE_API_ORIGIN=https://your-service.onrender.com

# Optional: full WebSocket URL if it differs from wss://<VITE_API_ORIGIN host>/ws
# VITE_WS_URL=wss://your-service.onrender.com/ws
